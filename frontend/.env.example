# Nginx Configuration (Backend Proxy)
# This is the internal URL of your backend service inside the cloud provider's network.
# Used by Nginx to proxy API requests to the Go API. Do NOT include http:// or a trailing slash.
# Example for Railway: bht-backend.railway.internal:8080
BACKEND_URL=bht-backend.railway.internal

# Frontend Configuration
# VITE_API_URL should almost ALWAYS BE LEFT EMPTY in production when using an Nginx proxy!
# If left empty, the frontend will automatically use '/api', allowing Nginx to securely handle the routing.
VITE_API_URL=
